<?xml version="1.0" encoding="utf-8" standalone="yes"?><rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom"><channel><title>EvQwQ 的博客</title><link>https://evqwq.github.io/</link><description>Recent content on EvQwQ 的博客</description><generator>Hugo</generator><language>zh-CN</language><lastBuildDate>Wed, 18 Mar 2026 11:00:00 +0800</lastBuildDate><atom:link href="https://evqwq.github.io/index.xml" rel="self" type="application/rss+xml"/><item><title>关于</title><link>https://evqwq.github.io/about/</link><pubDate>Wed, 18 Mar 2026 11:00:00 +0800</pubDate><guid>https://evqwq.github.io/about/</guid><description>&lt;h2 id="关于我"&gt;关于我&lt;/h2&gt;
